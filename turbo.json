{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.production.local",
        ".env.local",
        ".env.production",
        ".env"
      ],
      "outputs": ["dist/**", "server/**"]
    },
    "preview.build": {
      "dependsOn": ["^preview.build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.production.local",
        ".env.local",
        ".env.production",
        ".env"
      ],
      "outputs": ["dist/**", "server/**"]
    },
    "preview": {
      "dependsOn": ["preview.build"],
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "functions/**"]
    },
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.local",
        ".env.development.local",
        ".env.development",
        ".env"
      ],
      "cache": false
    },
    "start": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}