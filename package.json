{
  "name": "@wycey/wycey-monorepo",
  "private": true,
  "homepage": "https://wycey.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wycey/wycey.dev.git"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/workers-types": "^5.0.0",
    "@solid-primitives/event-listener": "^2.4.5",
    "@types/node": "^26.0.0",
    "@wycey/biome-config": "workspace:*",
    "lefthook": "^2.1.5",
    "npm-run-all2": "^9.0.0",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "turbo": "^2.9.5",
    "typescript": "6.0.3"
  },
  "scripts": {
    "prepare": "run-s setup:*",
    "setup:git": "lefthook install",
    "build": "turbo run build",
    "deploy": "turbo run deploy",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint.fix": "biome check --write .",
    "preview": "turbo run preview",
    "start": "turbo run start",
    "turbo": "turbo"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    }
  },
  "aube": {
    "allowBuilds": {
      "@sentry/cli": true,
      "esbuild": true,
      "sharp": true,
      "lefthook": true,
      "workerd": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "lefthook",
      "workerd"
    ]
  }
}