---
import { Picture } from "astro:assets";
import { getEntry, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { ArticleActionButtons } from "@/components/solid/ArticleActionButtons.client";
import RootLayout from "@/layouts/RootLayout.astro";
import { SITE_NAME } from "@/lib/constants";
import {
  createAuthorUrl, getArticle, getSortedArticles,
  markdownToReadableString
} from "@/lib/content";
import { dateNow, formatDate, parseDate } from "@/lib/content/date";
import { createArticleSchema } from "@/lib/content/json-ld";
import { truncateString } from "@/lib/utils/strings";

import "@/styles/typography.css";
import { FancyboxLoader } from "@/components/solid/FancyboxLoader.client";

export const getStaticPaths = (async () => {
  const articles = await getSortedArticles();
  
  return Promise.all(
    articles
      .map(async (article) => {
        const author = await getEntry(article.data.author);

        if (!author) {
          throw new Error(`Author ${article.data.author.id} not found for article ${article.id}`);
        }

        const category = await getEntry(article.data.category);

        if (!category) {
          throw new Error(`Category ${article.data.category.id} not found for article ${article.id}`);
        }
        
        return {
          params: {
            category: category.id,
            slug: article.id,
          },
          props: { article, author, category },
        }
      })
  );
}) satisfies GetStaticPaths;

const { article, author, category } = Astro.props;
const tags = article.data.tags
  .flatMap(tag =>
    category.data.tags?.find(t => t.slug === tag) as NonNullable<typeof category.data.tags>[number]
  );
const shareTitle = SITE_NAME;
const shareText = `${article.data.title} by ${author.data.name} · ${category.data.name} · ${SITE_NAME}`;

const ogImageUrl = new URL(`/og/${category.id}/${article.id}.png`, Astro.site).href;

const { Content, headings: rawHeadings, remarkPluginFrontmatter } = await render(article);

const validSlugs = new Set<string>(remarkPluginFrontmatter.validHeadingSlugs ?? []);
const headings = rawHeadings.filter((h) => validSlugs.has(h.slug));

const publishedAt = article.data.publishedAt ? parseDate(article.data.publishedAt) : undefined;
const updatedAt = remarkPluginFrontmatter.lastModified
  ? parseDate(remarkPluginFrontmatter.lastModified) 
  : publishedAt 
    ? publishedAt
    : dateNow();

const prevArticle = article.data.prevId ? await getArticle(article.data.prevId) : undefined;
const nextArticle = article.data.nextId ? await getArticle(article.data.nextId) : undefined;

const prevCategory = prevArticle?.data.category.id;
const nextCategory = nextArticle?.data.category.id;
const prevTitle = prevArticle?.data.title;
const nextTitle = nextArticle?.data.title;
---
<RootLayout
  title={`${article.data.title} · ${category.data.name}`}
  description={truncateString(await markdownToReadableString(article.body))}
  jsonLd={await createArticleSchema(article, updatedAt)}
  breadcrumbs={[
    { name: category.data.name, href: `/articles/${category.id}` },
  ]}
  headings={headings}
  ogImage={ogImageUrl}
  ogType="article"
  ogArticle={{
    ...(publishedAt ? { publishedTime: publishedAt.toISOString() } : {}),
    modifiedTime: updatedAt.toISOString(),
    authors: [author.data.name],
    section: category.data.name,
    tags: tags.map((t) => t.name),
  }}
>
  <section flex-auto flex flex-col h="full" class="relative brand-container">
    <article id="article" flex-auto>
      <h1 line-height="loose" font="bold" text="4xl" mb="2">{article.data.title}</h1>
      <section
        flex
        flex-wrap
        gap="8"
        mb="8"
      >
        <a
          href={createAuthorUrl(author.id)}
          flex
          items="center"
          gap="2"
          text="fg-muted hover:fg"
          transition-colors
          class="px-2 rounded-2 hover:bg-primary-bg-hover"
        >
          {author.data.avatar && (
            <Picture
              src={author.data.avatar}
              alt={`${author.data.name} のアバター画像`}
              width={48}
              height={48}
              priority={true}
              class="w-6 h-6 rounded-full object-contain"
            />
          )}
          <p class="whitespace-nowrap">{author.data.name}</p>
        </a>
        <div w="px" min-h="0" bg="border" rounded="full" />
        {
          tags.length > 0 &&
            <section flex items="center" gap="2">
              <p class="p-2 bg-primary-bg rounded-2">
                <span class="block i-lucide:hash text-primary-10" />
              </p>
              <ul flex items="center" gap="4">
                {tags.map(
                  tag => (
                    <li
                      class="hover:bg-bg-subtle px-2 py-1 rounded-2"
                      text="fg-muted hover:fg"
                      transition-colors
                      cursor="default"
                    >{tag.name}</li>
                  )
                )}
              </ul>
            </section>
        }
        <div flex-auto />
        <div flex flex-wrap items="center" gap="3" text="fg-muted" grid-col="4">
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:calendar-sync text-primary-10" />
            </p>
            <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt)}</time>
          </div>
          {publishedAt && (
            <div flex items="center" gap="2">
              <p class="p-2 bg-primary-bg rounded-2">
                <span class="block i-lucide:calendar text-primary-10" />
              </p>
              <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
            </div>
          )}
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:clock text-primary-10" />
            </p>
            <span>{article.data.minutesRead}</span>
          </div>
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:text text-primary-10" />
            </p>
            <span>{article.data.words} 字</span>
          </div>
        </div>
      </section>
      <section id="article-body" class="prose">
        <Content />

        <script is:inline src="https://platform.twitter.com/widgets.js" charset="utf-8" defer />
      </section>
    </article>
    <nav w="full" h="20" mt="4" grid grid-rows="2 md:1" grid-cols="1 md:2" items="center" justify="start" gap="4">
      {
        article.data.prevId
        ? <a
            href={`/articles/${prevCategory}/${article.data.prevId}`}
            flex
            gap="4"
            items="center"
            transition="colors"
            border="1 border"
            class="group bg-bg hover:bg-bg-subtle rounded-2 px-4 py-2"
          >
            <div text="2xl primary-10" transition="transform" translate-x="1 group-hover:0" class="i-lucide:chevron-left" />
            <section w="full">
              <p text="sm fg-muted">前の記事</p>
              <p text="group-hover:primary-10" transition="colors" font="medium">{prevTitle}</p>
            </section>
          </a>
          : <div />
      }
      {
        article.data.nextId
        ? <a
            href={`/articles/${nextCategory}/${article.data.nextId}`}
            flex
            flex-row-reverse
            gap="4"
            items="center"
            transition="colors"
            border="1 border"
            class="group bg-bg hover:bg-bg-subtle rounded-2 px-4 py-2"
          >
            <div text="2xl primary-10" transition="transform" translate-x="-1 group-hover:0" class="i-lucide:chevron-right" />
            <section w="full" text-align="end">
              <p text="sm fg-muted">次の記事</p>
              <p text="group-hover:primary-10" transition="colors" font="medium">{nextTitle}</p>
            </section>
          </a>
          : <div />
      }
    </nav>

    <ArticleActionButtons client:visible {shareTitle} {shareText} shareUrl={Astro.url.href} />
  </section>
  
  <FancyboxLoader client:idle />
</RootLayout>
