---
import { Picture } from "astro:assets";
import { getEntry, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import ArticleActionButtons from "@/components/ArticleActionButtons.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import { SITE_NAME } from "@/lib/constants";
import {
  createAuthorUrl, getSortedArticles, 
  markdownToReadableString
} from "@/lib/content";
import { dateNow, formatDate, parseDate } from "@/lib/content/date";
import { createArticleSchema } from "@/lib/content/json-ld";
import { truncateString } from "@/lib/utils/strings";

import "@/styles/typography.css";

export const getStaticPaths = (async () => {
  const articles = await getSortedArticles();
  
  return Promise.all(
    articles
      .map(async (article) => {
        const author = await getEntry("authors", article.data.author.id);

        if (!author) {
          throw new Error(`Author ${article.data.author.id} not found for article ${article.id}`);
        }

        const category = await getEntry("categories", article.data.category.id);
      
        if (!category) {
          throw new Error(`Category ${article.data.category.id} not found for article ${article.id}`);
        }
        
        return {
          params: {
            category: category.id,
            slug: article.id,
          },
          props: { article, author, category },
        }
      })
  );
}) satisfies GetStaticPaths;

const { article, author, category } = Astro.props;
const tags = article.data.tags.map(tag => category.data.tags?.find(t => t.slug === tag)).filter(Boolean) ?? [];
const shareTitle = `${article.data.title} by ${author.data.name} · ${category.data.name} · ${SITE_NAME}`;
const { Content, headings: rawHeadings, remarkPluginFrontmatter } = await render(article);

const validSlugs = new Set<string>(remarkPluginFrontmatter.validHeadingSlugs ?? []);
const headings = rawHeadings.filter((h) => validSlugs.has(h.slug));

const publishedAt = article.data.publishedAt ? parseDate(article.data.publishedAt) : undefined;
const updatedAt = remarkPluginFrontmatter.lastModified ? parseDate(remarkPluginFrontmatter.lastModified) 
  : publishedAt 
    ? publishedAt
    : dateNow();
const ogImageUrl = new URL(`/og/${category.id}/${article.id}.png`, Astro.site).href;
---
<RootLayout
  title={`${article.data.title} · ${category.data.name}`}
  description={truncateString(await markdownToReadableString(article.body))}
  jsonLd={await createArticleSchema(article, updatedAt)}
  breadcrumbs={[
    { name: category.data.name, href: `/articles/${category.id}` },
  ]}
  headings={headings}
  ogImage={ogImageUrl}
  ogType="article"
  ogArticle={{
    ...(publishedAt ? { publishedTime: publishedAt.toISOString() } : {}),
    modifiedTime: updatedAt.toISOString(),
    authors: [author.data.name],
    section: category.data.name,
    tags: tags.map((t) => t.name),
  }}
>
  <section flex-auto flex flex-col h="full" class="relative brand-container">
    <article id="article" flex-auto>
      <h1 line-height="loose" font="bold" text="4xl" mb="2">{article.data.title}</h1>
      <section
        flex
        flex-wrap
        gap="8"
        mb="8"
      >
        <a
          href={createAuthorUrl(author.id)}
          flex
          items="center"
          gap="2"
          text="fg-muted hover:fg"
          transition-colors
          class="px-2 rounded-2 hover:bg-primary-bg-hover"
        >
          {author.data.avatar && (
            <Picture
              src={author.data.avatar}
              alt={`${author.data.name} のアバター画像`}
              inferSize={true}
              priority={true}
              class="w-6 h-6 rounded-full object-contain"
            />
          )}
          <p class="whitespace-nowrap">{author.data.name}</p>
        </a>
        <div w="px" min-h="0" bg="border" rounded="full" />
        {
          tags.length > 0 &&
            <section flex items="center" gap="2">
              <p class="p-2 bg-primary-bg rounded-2">
                <span class="block i-lucide:hash text-primary-10" />
              </p>
              <ul flex items="center" gap="4">
                {tags.map(
                  tag => (
                    <li
                      class="hover:bg-bg-subtle px-2 py-1 rounded-2"
                      text="fg-muted hover:fg"
                      transition-colors
                      cursor="default"
                    >{tag.name}</li>
                  )
                )}
              </ul>
            </section>
        }
        <div flex-auto />
        <div flex flex-wrap items="center" gap="3" text="fg-muted" grid-col="4">
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:calendar-sync text-primary-10" />
            </p>
            <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt)}</time>
          </div>
          {publishedAt && (
            <div flex items="center" gap="2">
              <p class="p-2 bg-primary-bg rounded-2">
                <span class="block i-lucide:calendar text-primary-10" />
              </p>
              <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
            </div>
          )}
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:clock text-primary-10" />
            </p>
            <span>{article.data.minutesRead}</span>
          </div>
          <div flex items="center" gap="2">
            <p class="p-2 bg-primary-bg rounded-2">
              <span class="block i-lucide:text text-primary-10" />
            </p>
            <span>{article.data.words} 字</span>
          </div>
        </div>
      </section>
      <section id="article-body" class="prose">
        <Content />

        <script is:inline async src="https://platform.twitter.com/widgets.js" charset="utf-8" />
      </section>
    </article>
    <nav w="full" h="20" mt="4" grid grid-cols="2" items="center" justify="start" gap="4">
      {
        article.data.prevId
        ? <a
            href={article.data.prevId}
            flex
            gap="4"
            items="center"
            transition="colors"
            border="1 border"
            class="group bg-bg hover:bg-bg-subtle rounded-2 px-4 py-2"
          >
            <div text="2xl primary-10" transition="transform" translate-x="1 group-hover:0" class="i-lucide:chevron-left" />
            <section w="full">
              <p text="sm fg-muted">前の記事</p>
              <p text="group-hover:primary-10" transition="colors" font="medium">{article.data.prevTitle}</p>
            </section>
          </a>
          : <div />
      }
      {
        article.data.nextId
        ? <a
            href={article.data.nextId}
            flex
            flex-row-reverse
            gap="4"
            items="center"
            transition="colors"
            border="1 border"
            class="group bg-bg hover:bg-bg-subtle rounded-2 px-4 py-2"
          >
            <div text="2xl primary-10" transition="transform" translate-x="-1 group-hover:0" class="i-lucide:chevron-right" />
            <section w="full" text-align="end">
              <p text="sm fg-muted">次の記事</p>
              <p text="group-hover:primary-10" transition="colors" font="medium">{article.data.nextTitle}</p>
            </section>
          </a>
          : <div />
      }
    </nav>
    <footer flex flex-row-reverse m="t-8 -b-8" pb="8" gap="4" z="36" class="sticky inset-b-0 translate-y-full lg:hidden">
      <ArticleActionButtons {shareTitle} />
    </footer>
    <aside h="full" flex-col gap="4" class="absolute top-2 right--16 items-end hidden lg:flex">
      <section flex flex-col gap="4" class="sticky top-4">
        <ArticleActionButtons {shareTitle} />
      </section>
    </aside>
  </section>
</RootLayout>

<script>
  import type { FancyboxOptions } from "@fancyapps/ui";

  const fancyboxSelectors: string[] = [];
  let Fancybox: typeof import("@fancyapps/ui").Fancybox | null = null;
  
  const setupFancybox = async () => {
    const fancyboxSelector = "[data-fancybox]" as const;
    
    const hasImages = document.querySelector(fancyboxSelector);
    
    if (!hasImages) {
      return;
    }
    
    if (!Fancybox) {
      const module = await import("@fancyapps/ui");
      
      Fancybox = module.Fancybox;
      
      await import("@fancyapps/ui/dist/fancybox/fancybox.css");
    }

    if (fancyboxSelectors.length > 0) {
      return;
    }

    Fancybox.bind(fancyboxSelector, {
      Carousel: {
        Toolbar: {
          display: {
            left: ["counter"],
            middle: [
              "zoomIn",
              "zoomOut",
              "reset",
            ],
            right: ["thumbs", "close"],
          },
        },
        // biome-ignore lint/suspicious/noExplicitAny: Fancybox is too difficult to type
        formatCaption: (_carouselRef: any, slide: any) => {
          return slide.triggerEl?.nextElementSibling || "";
        }, 
      },
      hideScrollbar: false,
    } as unknown as FancyboxOptions);
    fancyboxSelectors.push(fancyboxSelector);
  };
  
  const setupFooterInteraction = () => {
    // スクロールに合わせてフッターを表示/非表示する
    const footer = document.querySelector("footer");
    const buttons = document.querySelectorAll("footer button");

    if (!footer) {
      throw new Error("Footer element not found");
    }

    setTimeout(() => {
      // 初期アニメーションを防止するため、ページ読み込み後にtransitionクラスを追加
      footer.classList.add("transition");
    });

    // 縦にスクロールできない場合は常にフッターを表示
    if (window.innerHeight >= document.body.offsetHeight) {
      footer.classList.remove("translate-y-full");

      for (const button of buttons) {
        button.classList.add("shadow-none");
      }
    }

    let lastScrollY = window.scrollY;

    window.addEventListener("scroll", () => {
      if (window.scrollY === lastScrollY) {
        return;
      }

      if (window.scrollY <= lastScrollY || window.innerHeight + window.scrollY >= document.body.offsetHeight - 400) {
        // スクロールアップ・下端付近に到達 - フッターを表示
        footer.classList.remove("translate-y-full");
      } else {
        // スクロールダウン - フッターを隠す
        footer.classList.add("translate-y-full");
      }

      if (window.scrollY <= 100) {
        // 上端付近に到達 - フッターを隠す
        footer.classList.add("translate-y-full");
      }

      // フッターがstickyで張り付いたら影をつける
      const footerRect = footer.getBoundingClientRect();

      if (footerRect.top <= window.innerHeight && footerRect.bottom >= window.innerHeight) {
        for (const button of buttons) {
          button.classList.remove("shadow-none");
        }
      } else {
        for (const button of buttons) {
          button.classList.add("shadow-none");
        }
      }

      lastScrollY = window.scrollY;
    });
  }
  
  setupFancybox();
  setupFooterInteraction();
</script>
