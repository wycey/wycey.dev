---
import { ShareButton, SquareButton } from "@/components/solid/SquareButton.client";

interface Props {
  shareTitle: string;
}

const { shareTitle } = Astro.props;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(`${shareTitle}\n`)}&url=${encodeURIComponent(Astro.url.href)}`;
---
<a href="#article" aria-label="一番上へ戻る">
  <SquareButton client:visible class="shadow-lg lg:shadow-none">
    <span class="block i-lucide:chevron-up" />
  </SquareButton>
</a>
<ShareButton client:visible {shareTitle} class="shadow-lg lg:shadow-none">
  <span class="block i-lucide:share" />
</ShareButton>
<a href={twitterShareUrl} target="_blank" rel="noopener noreferrer" aria-label="このページをTwitterで共有">
  <SquareButton client:visible class="hidden lg:block shadow-lg lg:shadow-none">
    <span class="block i-lucide:twitter" />
  </SquareButton>
</a>
