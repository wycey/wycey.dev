---
<meta name="color-scheme" content="light dark" />

<script is:inline>
  const applyTheme = (doc) => {
    const fromStorage = localStorage.getItem("theme");

    const meta = doc.querySelector('meta[name="color-scheme"]');

    if (!(meta instanceof HTMLMetaElement)) {
      throw new Error("Meta element with name 'color-scheme' not found");
    }

    if (fromStorage === "system" || fromStorage === null) {
      meta.setAttribute("content", "light dark");

      delete doc.documentElement.dataset.theme;
    } else {
      meta.setAttribute("content", fromStorage);

      doc.documentElement.dataset.theme = fromStorage;
    }
  };

  applyTheme(document);

  // Apply theme when navigating (SPA)
  document.addEventListener("astro:before-swap", (e) => {
    applyTheme(e.newDocument);
  });
</script>
